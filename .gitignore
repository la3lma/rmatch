scripts/__pycache__/

# Maven shade plugin artifacts
**/dependency-reduced-pom.xml

# Measurement files generated by tests
**/measurements/*.csv
docs/proposals/*/plantuml.jar
docs/proposals/*/build/
*/**/*.json.backup
