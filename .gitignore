# Large benchmark result files (exclude to avoid GitHub file size limits)
benchmarking/results/*.txt
benchmarking/results/*.log
benchmarking/results/jmh-*.json
benchmarking/results/macro-*.json
benchmarking/results/java-*.json
benchmarking/results/enhanced-*/
