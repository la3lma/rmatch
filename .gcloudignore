# Keep build uploads small and deterministic for Cloud Build image publishing.
.git
.gitignore
**/.DS_Store

# Local environments / caches
**/.venv
**/__pycache__
**/*.pyc
**/target

# Benchmark outputs and historical artifacts
extended-benchmarking/regex_bench_framework/results
extended-benchmarking/regex_bench_framework/reports
extended-benchmarking/regex_bench_framework/attic
extended-benchmarking/regex_bench_framework/backups
extended-benchmarking/regex_bench_framework/gcp_runs
extended-benchmarking/regex_bench_framework/benchmark_results.db
extended-benchmarking/regex_bench_framework/final_10k_option_a_report
extended-benchmarking/regex_bench_framework/timeout_fixed_*
extended-benchmarking/regex_bench_framework/debug_pattern_reuse_*

# Non-essential local payloads
extended-benchmarking/regex_bench_framework/large_corpora
extended-benchmarking/regex_bench_framework/tmp.txt
