# Keep build uploads small and deterministic for Cloud Build image publishing.
.git
.gitignore
**/.DS_Store

# Local environments / caches
**/.venv
**/__pycache__
**/*.pyc
**/target

# Benchmark outputs and historical artifacts
benchmarking/framework/regex_bench_framework/results
benchmarking/framework/regex_bench_framework/reports
benchmarking/framework/regex_bench_framework/attic
benchmarking/framework/regex_bench_framework/backups
benchmarking/framework/regex_bench_framework/gcp_runs
benchmarking/framework/regex_bench_framework/benchmark_results.db
benchmarking/framework/regex_bench_framework/final_10k_option_a_report
benchmarking/framework/regex_bench_framework/timeout_fixed_*
benchmarking/framework/regex_bench_framework/debug_pattern_reuse_*

# Non-essential local payloads
benchmarking/framework/regex_bench_framework/large_corpora
benchmarking/framework/regex_bench_framework/tmp.txt
