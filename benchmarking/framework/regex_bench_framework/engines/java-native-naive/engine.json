{
  "name": "java-native-naive",
  "version": "1.0",
  "description": "Naive java.util.regex baseline (sequential per-pattern scanning)",
  "type": "external",
  "command": ["bash", "runner.sh", "{patterns}", "{corpus}"],
  "requires": ["java", "javac"],
  "build_command": ["bash", "build.sh"],
  "output_format": {
    "match_pattern": "MATCHES=(\\d+)",
    "time_pattern": "ELAPSED_NS=(\\d+)",
    "compilation_pattern": "COMPILATION_NS=(\\d+)",
    "memory_pattern": "MEMORY_BYTES=([-+]?\\d+)",
    "patterns_compiled_pattern": "PATTERNS_COMPILED=(\\d+)",
    "patterns_failed_pattern": "PATTERNS_FAILED=(\\d+)"
  },
  "characteristics": {
    "backtracking": true,
    "linear_time_guarantee": false,
    "supports_backrefs": true,
    "supports_lookaround": true,
    "multi_pattern_optimized": false,
    "memory_profile": "moderate"
  },
  "platform_requirements": {
    "java_version": "8+",
    "memory_mb": 1024
  }
}
